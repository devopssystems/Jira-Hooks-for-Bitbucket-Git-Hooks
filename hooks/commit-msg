#!/usr/bin/env python3
# =============================================================================
# Git commit-msg hook — Local Commit Check
#
# Installation:
#   cp local-hooks/hooks/commit-msg .git/hooks/commit-msg
#   cp -r local-hooks/jhfb_hooks    .git/hooks/jhfb_hooks   # skip if pip install jhfb-hooks
#   chmod +x .git/hooks/commit-msg
#   cp local-hooks/commit-check.env.example .git/hooks/commit-check.env
# =============================================================================

import sys
from pathlib import Path

hook_dir = Path(__file__).resolve().parent
sys.path.insert(0, str(hook_dir))
sys.path.insert(0, str(hook_dir.parent))
from jhfb_hooks.runner import main_commit_msg

sys.exit(main_commit_msg(hook_dir))
